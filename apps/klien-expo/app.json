{
  "expo": {
    "name": "Mikala Klien",
    "slug": "mikala-klien",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mikala-klien",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1f1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mikalaglobalmedika.klien"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#10b981"
      },
      "package": "com.mikalaglobalmedika.klien",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://mikala-api.onrender.com/api",
      "router": {},
      "eas": {
        "projectId": "969e0f83-e5c7-4516-89e0-4af9c4c20615"
      }
    },
    "owner": "aditdeep"
  }
}
