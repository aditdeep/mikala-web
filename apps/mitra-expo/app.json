{
  "expo": {
    "name": "Mikala Mitra",
    "slug": "mikala-mitra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mikala-mitra",
    "userInterfaceStyle": "dark",
    "splash": { "image": "./assets/images/splash-icon.png", "resizeMode": "contain", "backgroundColor": "#0f0f1a" },
    "ios": { "supportsTablet": false, "bundleIdentifier": "com.mikalaglobalmedika.mitra" },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/images/adaptive-icon.png", "backgroundColor": "#7c3aed" }, "package": "com.mikalaglobalmedika.mitra" },
    "plugins": ["expo-router", "expo-secure-store", "expo-camera", "expo-image-picker"],
    "experiments": { "typedRoutes": true },
    "extra": { "apiUrl": "https://mikala-api.onrender.com/api" }
  }
}
